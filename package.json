{
  "name": "openobserve-mcp",
  "version": "1.0.3",
  "description": "MCP for OpenObserve with multi-instance support, batching, and parallel queries",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "openobserve-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "config/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "lru-cache": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "openobserve",
    "observability",
    "logs",
    "traces",
    "metrics"
  ],
  "author": "Adarsh B A",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/adarshba/openobserve-mcp"
  }
}
